---
import BaseLayout from "@/layouts/BaseLayout.astro";
import WhyUsPage from "@/views/WhyUs";
import { getBreadcrumbSchema, getPageSchema, SITE_URL } from "@/lib/seo";

const title = "Why Choose Vicky Safety Nets In Bangalore";
const description =
  "Learn about Vicky Safety Nets, our installation quality, materials, service coverage across Bangalore, and why customers trust our safety net solutions.";
const path = "/why-us/";
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath={path}
  schema={[
    getPageSchema(`${SITE_URL}${path}`, title, description),
    getBreadcrumbSchema([
      { name: "Home", path: "/" },
      { name: "Why Us", path },
    ]),
  ]}
>
  <WhyUsPage client:load />
</BaseLayout>
